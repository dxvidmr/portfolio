# === Turso (libSQL) ===
# Uso EXCLUSIVAMENTE server-side. Nunca exponer al cliente (no usar prefijo PUBLIC_).
# URL: turso db show <db> --url
# TOKEN: turso db tokens create <db>
TURSO_DATABASE_URL=libsql://<db-name>-<org>.<region>.turso.io
TURSO_AUTH_TOKEN=

# === Dashboard /admin (Auth.js + GitHub OAuth; ver docs/guia-fase2-oauth.md) ===
# AUTH_SECRET: openssl rand -base64 32 (uno distinto por entorno).
# AUTH_GITHUB_*: de la OAuth App (dev en local, prod en Vercel).
# ADMIN_GITHUB_ID: ID numérico inmutable del único usuario autorizado.
# En Vercel añadir además AUTH_TRUST_HOST=true (no necesario en local).
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
ADMIN_GITHUB_ID=

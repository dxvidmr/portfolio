# === Turso (libSQL) ===
# Uso EXCLUSIVAMENTE server-side. Nunca exponer al cliente (no usar prefijo PUBLIC_).
# URL: turso db show <db> --url
# TOKEN: turso db tokens create <db>
TURSO_DATABASE_URL=libsql://<db-name>-<org>.<region>.turso.io
TURSO_AUTH_TOKEN=

# === Dashboard /admin (autenticación básica, se usará en hooks.server.ts) ===
# Rellenar con valores propios. No commitear valores reales.
ADMIN_USERNAME=
ADMIN_PASSWORD=
